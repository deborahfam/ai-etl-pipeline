# =============================================================================
# FlowAI ETL - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# At least ONE provider must be configured.

# --- LLM Provider Selection ---
# Options: anthropic, openai, lmstudio, openrouter
# The gateway auto-detects available providers from env vars.
# Set this to override the default priority order.
# Options: anthropic, openai, lmstudio, openrouter
LLM_PROVIDER=anthropic

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# --- LM Studio (local, OpenAI-compatible) ---
LM_STUDIO_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=local-model

# --- OpenRouter (multi-model gateway) ---
OPENROUTER_API_KEY=sk-or-v1-...
# Free options (check https://openrouter.ai/models — IDs change over time):
#   openrouter/free          → router: picks a capable free model (text + vision when needed)
#   google/gemma-4-31b-it:free → strong free multimodal (vision + text)
#   nvidia/nemotron-3-nano-30b-a3b:free → free, tools-friendly, high context
OPENROUTER_MODEL=openrouter/free

# --- General ---
LOG_LEVEL=INFO
LLM_CACHE_ENABLED=true
LLM_MAX_RETRIES=3
